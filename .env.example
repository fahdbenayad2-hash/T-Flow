# Femme Soir — Environment Variables
# Copy this to .env and fill in your values

# Supabase (Lovable Cloud)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
APP_SUPABASE_URL=https://your-project-ref.supabase.co
APP_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Apps Script (DO NOT prefix with VITE_ — server only)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Default Admin Email (auto-assigned admin role on first signup)
DEFAULT_ADMIN_EMAIL=fahdbenayad2@gmail.com
